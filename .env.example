# Slack integration (optional)
# Get tokens from https://api.slack.com/apps → OAuth & Permissions
# Use one SLACK_TOKEN_<NAME> per workspace:
SLACK_TOKEN_MYCOMPANY=xoxp-your-token-here
SLACK_TOKEN_SIDEJOB=xoxp-another-token-here

